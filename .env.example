# --- Required ---

# Secret used to sign auth cookies.
# Generate with: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string

# Root secret for encrypting stored credentials (API keys, tokens).
# Falls back to COOKIE_SECRET if unset — set it on new installs. To rotate
# it later: set the new value, then re-encrypt stored credentials with
#   OLD_ENCRYPTION_SECRET=<old> pnpm --filter @rabblehq/server rotate:secret
# ENCRYPTION_SECRET=change-me-too

# --- Optional ---

# Default Anthropic API key used by built-in Claude models when the org
# hasn't configured one in Admin > Models.
# ANTHROPIC_API_KEY=

# Host port for the app when using docker compose (default 3080).
# PORT=3080

# Set true when serving behind HTTPS so auth cookies are marked Secure.
# COOKIE_SECURE=true

# Public https origin Slack can reach (managed Slack setup). When unset,
# `mise run dev` auto-sets it via a cloudflared quick-tunnel.
# PUBLIC_URL=https://rabble.example.com

# --- Only for running the server outside Docker (pnpm dev) ---

# DATABASE_URL=postgres://rabble:rabble@localhost:55432/rabble
