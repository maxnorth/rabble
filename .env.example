# Postgres connection
DATABASE_URL=postgres://rabble:rabble@localhost:5432/rabble

# Server
PORT=3080
# Secret used to sign auth session cookies. Generate with: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string

# Optional: default Anthropic API key used by built-in models when the org
# hasn't configured one in Admin > Models.
# ANTHROPIC_API_KEY=
